<!DOCTYPE html>
<html>
  <head>
    <title>Medicoo Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <style>
      :root {
        --bg: #f4efe7;
        --panel: #fffdf8;
        --ink: #1f2933;
        --muted: #64748b;
        --accent: #c2410c;
        --accent-soft: #ffedd5;
        --line: #e7dccd;
        --green: #166534;
        --green-soft: #dcfce7;
        --red: #b91c1c;
        --red-soft: #fee2e2;
        --orange: #b45309;
        --orange-soft: #ffedd5;
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Georgia, "Times New Roman", serif; background: radial-gradient(circle at top, #fff8ef, var(--bg)); color: var(--ink); }
      a { color: inherit; text-decoration: none; }
      .shell { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
      .sidebar { background: #1c1917; color: #f5f5f4; padding: 28px 20px; }
      .sidebar h1 { font-size: 1.5rem; margin: 0 0 8px; }
      .sidebar p { color: #d6d3d1; font-size: 0.95rem; line-height: 1.4; }
      .nav { margin-top: 24px; display: grid; gap: 10px; }
      .nav a { padding: 12px 14px; border-radius: 12px; background: rgba(255,255,255,0.04); }
      .nav a:hover { background: rgba(255,255,255,0.1); }
      .content { padding: 28px; }
      .topbar { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-bottom: 24px; }
      .panel { background: var(--panel); border: 1px solid var(--line); border-radius: 20px; padding: 22px; box-shadow: 0 10px 30px rgba(28,25,23,0.05); }
      .grid { display: grid; gap: 20px; }
      .grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .table { width: 100%; border-collapse: collapse; }
      .table th, .table td { padding: 12px 10px; border-bottom: 1px solid var(--line); text-align: left; vertical-align: top; }
      .table th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); }
      .metric { font-size: 2rem; margin: 8px 0 0; }
      .muted { color: var(--muted); }
      .badge { display: inline-block; padding: 5px 10px; border-radius: 999px; font-size: 0.85rem; }
      .badge-green { background: var(--green-soft); color: var(--green); }
      .badge-orange { background: var(--orange-soft); color: var(--orange); }
      .badge-red { background: var(--red-soft); color: var(--red); }
      .flash { margin-bottom: 16px; padding: 12px 14px; border-radius: 12px; }
      .flash.notice { background: var(--green-soft); color: var(--green); }
      .flash.alert { background: var(--red-soft); color: var(--red); }
      .actions, .form-row { display: flex; gap: 12px; flex-wrap: wrap; }
      input, select, textarea, button { width: 100%; padding: 11px 12px; border: 1px solid #d6c8b5; border-radius: 12px; font: inherit; background: white; }
      textarea { min-height: 120px; }
      button, .button { width: auto; cursor: pointer; background: var(--accent); color: white; border: none; }
      .button-secondary { background: #e7dccd; color: var(--ink); }
      .detail-list { display: grid; grid-template-columns: 180px 1fr; gap: 10px 14px; }
      @media (max-width: 960px) {
        .shell { grid-template-columns: 1fr; }
        .grid-4, .grid-2 { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <h1>Medicoo Admin</h1>
        <p>Licensing, billing visibility, and Groq key inventory in one place.</p>
        <nav class="nav">
          <%= link_to "Overview", admin_dashboard_path %>
          <%= link_to "Customers", admin_customers_path %>
          <%= link_to "Groq Keys", admin_groq_keys_path %>
          <%= button_to "Logout", "/logout", method: :delete, class: "button button-secondary" %>
        </nav>
      </aside>
      <main class="content">
        <% flash.each do |type, message| %>
          <div class="flash <%= type %>"><%= message %></div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
